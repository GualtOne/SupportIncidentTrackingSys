<Window x:Class="SupportIncidentTrackingSys.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SupportIncidentTrackingSys"
        mc:Ignorable="d"
        Title="Редактирования" Height="400" Width="350">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Подразделение:" Margin="0,0,0,5"/>
            <ComboBox Margin="0,0,0,15" x:Name="SubdivisionComboBox" ItemsSource="{Binding Subdivisions}" IsEditable="False" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSubdivision}"  />

            <TextBlock Text="Категорию:" Margin="0,0,0,5"/>
            <ComboBox Margin="0,0,0,15" x:Name="CategoryComboBox" ItemsSource="{Binding Categories}" IsEditable="False" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCategory}"  />

            <TextBlock Text="Описание:" Margin="0,0,0,5"/>
            <TextBox x:Name="CommentTextBox" AcceptsReturn="True" MinHeight="50" 
                      Margin="0,0,0,15"/>

            <TextBlock Text="Приоритет:" Margin="0,0,0,5"/>
            <ComboBox Margin="0,0,0,15" 
                      x:Name="PriorityComboBox" 
                      ItemsSource="{Binding Priorities}" 
                      DisplayMemberPath="Name" 
                      IsEditable="False" 
                      SelectedItem="{Binding SelectedPriority}"  />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" >
                <Button Content="Изменить" Click="OkButton_Click" Width="127" Margin="0,0,10,0" IsDefault="True" IsEnabled="{Binding IsDataLoaded}"/>
                <Button Content="Отмена" Click="CancelButton_Click" Width="70" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
