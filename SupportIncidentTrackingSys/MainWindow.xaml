<Window x:Class="SupportIncidentTrackingSys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SupportIncidentTrackingSys"
        mc:Ignorable="d"
        Title="MainWindow" Height="562" Width="1373">
    <TabControl Margin="0,0,0,-6">
        <TabItem Header="Таблица инцедентов" DataContext="{Binding IncidentsVM}">
            <Grid Background="#FFE5E5E5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ToolBar x:Name="MyToolbar" 
                         Grid.Row="1" 
                         Visibility="Visible">
                    <Button Content="Зарегистрировать инцидент" Click="AddItem_Click" ToolTip="Добавить транзакцию" 
                            BorderBrush="LightGray" Background="WhiteSmoke" Width="167"/>
                </ToolBar>

                <TextBlock Text="Таблица инцедентов:" Grid.Row="0" Margin="0,0,0,5"/>
                <DataGrid x:Name="MyDataGrid" 
                          Grid.Row="2"
                          ItemsSource="{Binding Incidents}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="Auto"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="100"/>
                        <DataGridTextColumn Header="Подразделения" Binding="{Binding Subdivison}" Width="130"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="130"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="100"/>
                        <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Regdate, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Срок реакции" Binding="{Binding ResponseTime, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Срок решения" Binding="{Binding DecisionDeadline, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Ответственный" Binding="{Binding Responsibale}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Редактировать" Click="EditItem_Click"/>
                            <MenuItem Header="Удалить" Click="DeleteItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <Border Grid.Row="3" 
                        Background="LightGray" 
                        Padding="5" 
                        Margin="5,0,5,5">
                    <TextBlock Text="{Binding Transactions.Count, StringFormat='Всего транзакций: {0}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                </Border>

                <TextBlock Text="История действий:" Grid.Row="4" Margin="0,0,0,5"/>
                <DataGrid x:Name="HistoryDataGA" 
           Grid.Row="5"
           ItemsSource="{Binding Incidents}"
           AutoGenerateColumns="False" 
           IsReadOnly="True"
           SelectionMode="Single"
           SelectionUnit="FullRow"
           Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="Auto"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="100"/>
                        <DataGridTextColumn Header="Подразделения" Binding="{Binding Subdivison}" Width="130"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="130"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="100"/>
                        <DataGridTextColumn Header="Дата регистрации" Binding="{Binding Regdate, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Срок реакции" Binding="{Binding ResponseTime, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Срок решения" Binding="{Binding DecisionDeadline, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Ответственный" Binding="{Binding Responsibale}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Редактировать" Click="EditItem_Click"/>
                            <MenuItem Header="Удалить" Click="DeleteItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Grid>
        </TabItem>
        <TabItem Header="Таблица транзакций">

        </TabItem>
    </TabControl>
</Window>
